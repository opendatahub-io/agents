# NPS Agent Environment Variables
# Copy this file to .env and fill in your values:
#   cp env.sample .env

# =============================================================================
# API Keys (Required)
# =============================================================================

# OpenAI API key - get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# OpenAI-compatible base URL (e.g., OpenAI, vLLM, llama.cpp, Ollama)
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name to use
OPENAI_MODEL_NAME=<Add-model-name-here like gpt-4o>

# NPS API key - get from https://www.nps.gov/subjects/developer/get-started.htm
NPS_API_KEY=your-nps-api-key-here

# =============================================================================
# MLflow Configuration (Required for RHOAI deployment)
# =============================================================================

# Your RHOAI MLflow URL
MLFLOW_TRACKING_URI=https://data-science-gateway.apps.<your-cluster>.openshiftapps.com/mlflow/

# MLflow workspace (typically same as your OpenShift namespace)
MLFLOW_WORKSPACE=nps-agent-<namespace>

# Experiment name in MLflow (works in both local and RHOAI environments)
MLFLOW_EXPERIMENT_NAME=nps-agent

# MLflow tracking auth method (use "kubernetes" for RHOAI deployment)
MLFLOW_TRACKING_AUTH=kubernetes

# MLflow auth token (set via: oc whoami -t)
# MLFLOW_TRACKING_TOKEN=sha256~your-token-here

# =============================================================================
# OpenShift Configuration (Required for deployment)
# =============================================================================

# Your OpenShift project/namespace
OPENSHIFT_NAMESPACE=nps-agent-<namespace>

# OpenShift internal image registry
IMAGE_REGISTRY=image-registry.openshift-image-registry.svc:5000

